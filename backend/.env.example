# API key de Google Gemini (obligatorio) — consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Gemini a usar (opcional, por defecto gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Puerto del servidor (opcional, por defecto 3001)
PORT=3001

# Entorno de ejecución: development | production
NODE_ENV=development

# Orígenes permitidos en producción (separados por coma si hay más de uno)
# Ejemplo: https://que-comemos-hoy.vercel.app,https://www.midominio.com
ALLOWED_ORIGIN=https://tu-frontend.com

# API key de Google Gemini (obligatorio) — consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de Gemini a usar (opcional, por defecto gemini-flash-lite-latest, con cuota
# diaria gratuita más alta que gemini-2.5-flash, que solo permite 20 req/día gratis)
GEMINI_MODEL=gemini-flash-lite-latest

# Puerto del servidor (opcional, por defecto 3001)
PORT=3001

# Entorno de ejecución: development | production
NODE_ENV=development

# Orígenes permitidos en producción (separados por coma si hay más de uno)
# Ejemplo: https://que-comemos-hoy.vercel.app,https://www.midominio.com
ALLOWED_ORIGIN=https://tu-frontend.com

# API key de Pexels para imágenes de platos (opcional — si no se configura, las tarjetas usan emojis como placeholder)
# Consigue una gratis en https://www.pexels.com/api/ — no requiere tarjeta de crédito
PEXELS_API_KEY=

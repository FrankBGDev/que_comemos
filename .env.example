# URL del backend (proxy de Gemini). En local apunta a tu servidor Express;
# en producción, a la URL pública de tu despliegue en Render/Railway.
VITE_API_URL=http://localhost:3001

# Supabase (autenticación + perfil sincronizado por usuario). Obtén estos valores
# en tu proyecto de Supabase → Project Settings → API. La anon key es pública por
# diseño (la protección real la da Row Level Security en la base de datos).
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
